# ========================================
# GAS SPONSORSHIP
# ========================================

# Gas Treasury (ACTIVE - For EOA Wallets)
# Treasury wallet that automatically funds user wallets with ETH for gas fees
# Provides gasless experience until smart contract wallets are implemented
# Generate private key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then add 0x prefix
GAS_TREASURY_PRIVATE_KEY=0x_your_treasury_private_key_here
# Treasury Address: 0x072c5f40cc75ee0eb0a8b2125dd2cc82bada5311

# Coinbase Paymaster (DISABLED - Requires Smart Contract Wallets)
# Will be enabled when migrating to ERC-4337 smart contract wallets
# Get API key from: https://portal.cdp.coinbase.com/
COINBASE_PAYMASTER_API_KEY=cb_paymaster_your_api_key_here
COINBASE_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/paymaster
COINBASE_BUNDLER_URL=https://api.developer.coinbase.com/rpc/v1/base/bundler

